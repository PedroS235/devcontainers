{
  "id": "gui-support",
  "version": "1.1.0",
  "name": "X11 GUI Support",
  "description": "Enables X11 forwarding for running GUI applications in the container",
  "documentationURL": "https://github.com/PedroS235/devcontainers",
  "mounts": [
    {
      "source": "/tmp/.X11-unix",
      "target": "/tmp/.X11-unix",
      "type": "bind"
    }
  ],
  "runArgs": [
    "--device=/dev/dri",
    "--gpus=all",
    "--group-add=video"
  ],
  "init": true,
  "customizations": {
    "vscode": {
      "settings": {}
    }
  }
}
